<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RiotPicker.Controls.PriorityListControl">

    <Grid RowDefinitions="*,Auto,Auto">

        <!-- Scrollable list -->
        <Border Grid.Row="0" Background="#FF1A1A1A" CornerRadius="8" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ItemsPanel" Spacing="2"/>
            </ScrollViewer>
        </Border>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText" Grid.Row="0"
                   Text="Liste bos - asagidan ekleyin"
                   Foreground="#FF888888" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsVisible="False"/>

        <!-- Search -->
        <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,5,0,0"
                 Watermark="Ara..."
                 Background="#FF2A2A2A" Foreground="#FFE0E0E0"
                 BorderBrush="#FF3A3A3A" BorderThickness="1"
                 CornerRadius="4" Padding="6,4"
                 KeyUp="SearchBox_KeyUp"/>

        <!-- Search results popup -->
        <Popup x:Name="SearchPopup" Grid.Row="1"
               PlacementTarget="{Binding #SearchBox}"
               Placement="Top" IsLightDismissEnabled="True">
            <Border Background="#FF1E1E1E" CornerRadius="6"
                    BorderBrush="#FF3A3A3A" BorderThickness="1"
                    MaxHeight="200" MinWidth="200" Padding="2">
                <StackPanel x:Name="SearchResultsPanel" Spacing="1"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
