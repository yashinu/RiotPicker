<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RiotPicker.Views"
        xmlns:conv="clr-namespace:RiotPicker.Converters"
        xmlns:vm="clr-namespace:RiotPicker.ViewModels"
        x:Class="RiotPicker.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Riot Picker"
        Width="520" Height="720"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#FF191919"
        SystemDecorations="Full"
        Icon="avares://RiotPicker/Resources/logo.png">

    <Window.Resources>
        <conv:StatusColorConverter x:Key="StatusColorConv"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#FF1A1A2E" Padding="15,10"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RIOT PICKER" FontSize="18" FontWeight="Bold"
                               Foreground="#FFE74C3C"/>
                    <TextBlock Text="by Yashinu" FontSize="10"
                               Foreground="#FF666666" Margin="8,0,0,6"
                               VerticalAlignment="Bottom"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <!-- Language button -->
                    <Button x:Name="LangButton" Width="36" Height="28"
                            FontSize="11" FontWeight="Bold"
                            Foreground="#FFE0E0E0"
                            Background="#FF353535" BorderThickness="0"
                            CornerRadius="4"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="Language_Click"/>
                    <Button Content="&#x2014;" Width="36" Height="28"
                            FontSize="14" Foreground="Gray"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="4"
                            HorizontalContentAlignment="Center"
                            Click="Minimize_Click"/>
                    <Button Content="&#x2715;" Width="36" Height="28"
                            FontSize="14" Foreground="White"
                            Background="#FFE74C3C" BorderThickness="0"
                            CornerRadius="4"
                            HorizontalContentAlignment="Center"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status + Toggle Row -->
        <Grid Grid.Row="1" Margin="10,8,10,0" ColumnDefinitions="*,8,*">

            <!-- LoL card -->
            <Border Grid.Column="0" Background="#FF1E1E1E" CornerRadius="8" Padding="8,6">
                <StackPanel Spacing="3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleSwitch IsChecked="{Binding LolEnabled, Mode=TwoWay}"
                                      OnContent="" OffContent=""
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="LoL" FontSize="12" FontWeight="Bold"
                                   Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="8" Height="8"
                                 VerticalAlignment="Center"
                                 Fill="{Binding LolStatusColor, Converter={StaticResource StatusColorConv}}"/>
                        <TextBlock Text="{Binding LolStatusText}" FontSize="10"
                                   Foreground="#FF888888" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Valorant card -->
            <Border Grid.Column="2" Background="#FF1E1E1E" CornerRadius="8" Padding="8,6">
                <StackPanel Spacing="3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleSwitch IsChecked="{Binding ValEnabled, Mode=TwoWay}"
                                      OnContent="" OffContent=""
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="VAL" FontSize="12" FontWeight="Bold"
                                   Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="8" Height="8"
                                 VerticalAlignment="Center"
                                 Fill="{Binding ValStatusColor, Converter={StaticResource StatusColorConv}}"/>
                        <TextBlock Text="{Binding ValStatusText}" FontSize="10"
                                   Foreground="#FF888888" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Tabs -->
        <TabControl Grid.Row="2" Margin="10,8,10,10">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="13"/>
                </Style>
                <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Foreground" Value="#FFE74C3C"/>
                </Style>
                <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </Style>
            </TabControl.Styles>
            <TabItem Header="League of Legends">
                <views:LolTabView DataContext="{Binding LolVm}"/>
            </TabItem>
            <TabItem Header="Valorant">
                <views:ValorantTabView DataContext="{Binding ValVm}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
